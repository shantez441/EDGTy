	<script type="text/javascript">
      //<![CDATA[
      var VMObject = function () {
        this.mHMType            = 2,
        this.mFrameWidth        = 820,
        this.mFrameHeightDelta  = 50,
        this.mFrameObject       = null,
        this.mPlatform          = navigator.platform,
        this.mIsIE              = false,
        this.mIEVersion         = 0,
        this.mWidthScale        = 1,
        this.mHeightScale       = 1
      }

      VMObject.prototype.init = function () {
        this.mFrameObject = document.getElementById("cipher");

        if (this.mFrameObject) {
          var _doc =  this.mFrameObject.contentDocument || this.mFrameObject.contentWindow.document;
          if (_doc) { _doc.write(""); }
          if (this.mHMType == 2) {
            this.mFrameObject.scrolling     = "no";
            document.body.style.overflow    = "auto";
          } else if (this.mHMType == 3) {
            this.mFrameObject.scrolling     = "yes";
            this.mFrameObject.style.width   = "100%";
            this.mFrameObject.style.height  = "100%";
            var aPrintObj = document.getElementById ("print");
            if (aPrintObj) {
              aPrintObj.style.position  = "absolute";
              aPrintObj.style.top       = "0%";
              aPrintObj.style.left      = "85%";
            }
          }
        }

        this.mFlatform  = navigator.platform;
        try {
          this.mIEVersion = navigator.appVersion.match(/MSIE (\d\.\d)/)[1] - 0;
        } catch (e) {
          this.mIEVersion = 0;
        }
        if (this.mIEVersion > 0) {
          this.mIsIE = true;
        }

        if (this.mIsIE) {
          switch (this.mIEVersion) {
            case 6:
            case 7:
            this.mWidthScale = 1.1;
            this.mHeightScale = 0.9;
            break;
          }
          this.mFrameHeightDelta = this.mFrameHeightDelta * this.mHeightScale;
          this.mFrameWidth = this.mFrameWidth * this.mWidthScale;
        }
      }

      VMObject.prototype.println = function (args) {
        if (window.console) {
          window.console.log (args);
        }
      }

      VMObject.prototype.resizeFrame = function () {
        if (this.mFrameObject) {
          if (this.mHMType == 1) {
            this.resizeFrameType1 (this.mFrameObject);
            } else if (this.mHMType == 2) {
            this.resizeFrameType2 (this.mFrameObject);
            } else {
            this.resizeFrameType3 (this.mFrameObject);
          }
        }
      }

      VMObject.prototype.resizeFrameType1 = function (iframeObj) {
        if (iframeObj) {
          var resizeWidth, resizeHeight;
          resizeWidth = this.mFrameWidth;
          if (document.body.scrollHeight) {
            resizeHeight  = document.body.clientHeight - this.mFrameHeightDelta;
            } else {
            resizeHeight = 0;
          }

          if (iframeObj.style) {
            iframeObj.style.width   = resizeWidth + "px";
            if (resizeHeight > 0) {
              iframeObj.style.height  = resizeHeight + "px";
              } else {
              iframeObj.style.height  = 0 + "px";
            }
          }
        }
      }

      VMObject.prototype.resizeFrameType2 = function (iframeObj) {
          if (iframeObj) {
            var innerDoc = iframeObj.contentWindow.document || iframeObj.contentDocument;
            if(innerDoc.height) {
          	if(innerDoc.height != 0)  
                iframeObj.style.height  = innerDoc.height + "px";
          	if(innerDoc.width != 0)
                iframeObj.style.width   = innerDoc.width + "px";
            } else {
              if (innerDoc.body) {
    			  if(innerDoc.body.scrollHeight != 0)	
                  iframeObj.style.height  = innerDoc.body.scrollHeight + "px";
    			  if(innerDoc.body.scrollWidth != 0)
                  iframeObj.style.width   = innerDoc.body.scrollWidth + "px";
              }
            }
          }
        }

      VMObject.prototype.resizeFrameType3 = function (iframeObj) {
      }

      VMObject.prototype.printIframe = function () {
        if (this.mFrameObject) {
          var _win = this.mFrameObject.contentWindow || this.mFrameObject;
          _win.focus();
          _win.print();
        }
      }

      VMObject.prototype.addEvent = function (elem, type, eventHandle) {
        if (elem == null || elem == undefined) return;

        if ( elem.addEventListener ) {
          elem.addEventListener( type, eventHandle, false );
          } else if ( elem.attachEvent ) {
          elem.attachEvent( "on" + type, eventHandle );
          } else {
          elem["on"+type]=eventHandle;
        }
      }

      VMObject.prototype.keypadInit = function (elepwd) {
    	  if(typeof(dill) == "undefined") {
    		  return false;
    	  } else {
	          dill.service.init(elepwd.getAttribute('id'), undefined, function() {
	              elepwd.focus();
	          });
    	  }
    	  return true;
      }

      var gVMObject = new VMObject();

      function ready () {
        gVMObject.init();
        gVMObject.addEvent (window, "resize", resizeFrame);

		document.getElementById("pop_content").style.visibility="visible";
		if(document.body.clientWidth / 2 - 240 > 0 )
			document.getElementById("pop_content").style.left= document.body.clientWidth / 2 - 240 + "px";
		else 
			document.getElementById("pop_content").style.left= "10px";

		// 베너 영역 설정
		var bannerStr = "";
		try{
			if(bannerStr == "" && banner != null && banner != "")
				bannerStr = banner;
		} catch(e) { bannerStr = ""; }
		
		try{
			if( bannerURL != null && bannerURL != "" )
				bannerStr = bannerURL;
		} catch(e){	bannerStr = "";	}
		
		if( bannerStr != null && bannerStr != '') {
			document.getElementById('ly_banner').style.background= "url('" + bannerStr + "') no-repeat";
		} 
		// 베너 영역 설정 끝

        if (navigator.platform == "Win32" ||
            navigator.platform == "MacIntel" || navigator.platform == 'iPad' ||
            navigator.platform == "Linux i686" || navigator.platform == "Linux x686") {
          if (document.getElementById("noscript") != null) {
            document.getElementById("noscript").style.width="100%";
          }
        }

        // 키패드 영역 설정
        setKeypad();
        // 키패드 영역 설정 끝
      
		var userLang = navigator.language || navigator.userLanguage; 
		var infoText = "";
  		if(userLang.indexOf("ko") != -1) {
  			try{
  				if(textStr_ko != null && textStr_ko != "" ) 
	  				infoText = textStr_ko;
			} catch(e) { infoText = ""; }
  			
  			try {
  				if(infoText == "" && infoText_ko != null && infoText_ko != "") 
	  				infoText = infoText_ko;
  			} catch(e) { infoText = ""; }
  			if(infoText == "") {
  				infoText="본 메일은 고객님의 정보보호를 위해 <font class='cryto_text'>암호화된 보안메일</font>입니다.<br/>메일을 확인하시려면 아래의 내용을 입력후 확인해 주시기 바랍니다.<br/><br/><div class='ly_body2'><b>* 개인회원</b> - 생년월일 6자리 입력</div><div class='ly_body2'><b>* 법인고객</b> - 사업자번호 앞 6자리 입력</div>";
  			}
			document.getElementById("ly_body").innerHTML=infoText; 
			if( document.getElementById("confirm") )
				document.getElementById("confirm").value="확인";
			
			vestmail_msg_download_link  = "저장하려면 여기를 클릭하세요.";
			vestmail_msg_wrong_password = "비밀번호 입력이 잘못되었습니다.";
			vestmail_msg_processing     = "복호화 진행 중입니다.";
			vestmail_msg_not_supported_browser = "지원하지 않는 브라우저입니다.";
			vestmail_msg_not_supported_attachfile = "첨부파일 기능을 지원하지 않습니다.아래의 자세한 사항을 확인하여 주십시오.";
			
		} else if( userLang.indexOf("en") != -1){
			try{
  				if(textStr_en != null && textStr_en != "" ) 
	  				infoText = textStr_en;
			} catch(e) { infoText = ""; }
  			
  			try {
  				if(infoText == "" && infoText_en != null && infoText_en != "") 
	  				infoText = infoText_en;
  			} catch(e) { infoText = "";	}
  			
  			if(infoText == "") {
  				infoText="This is an encrypted, <font style='color:#ff0760;font-weight:bold;'>secure e-mail</font> for your privacy.<br/>To check your mail, please check and enter the information below.<br/><br/><div class='ly_body2'>* Private customers : Resident on the 6-digit date of birth</div><br/><div class='ly_body2'>* Corporate customers :10-digit Business Number</div><br/>";
  			}
  			
			var ly_body = document.getElementById("ly_body");
			ly_body.innerHTML=infoText;
			if( document.getElementById("confirm") )  
				document.getElementById("confirm").value="confirm";
			ly_body.style.letterSpacing="-0.1em";

			if(document.getElementById("ly_header"))
				document.getElementById("ly_header").innerHTML="Secure e-mail, password input";

			document.getElementById("password").placeholder="input password";

			vestmail_msg_download_link  = "Please click here to save.";
			vestmail_msg_wrong_password = "Enter password is invalid.";
			vestmail_msg_processing     = "Progress is being decoded.";
			vestmail_msg_not_supported_browser = "Unsupported Browser.";
			vestmail_msg_not_supported_attachfile = "Attached Files feature is not supported. Please check the details below.";
		} else {
			try{
  				if(textStr_other != null && textStr_other != "" ) 
	  				infoText = textStr_other;
			} catch(e) { infoText = ""; }
  			
  			try {
  				if(infoText == "" && infoText_other != null && infoText_other != "") 
	  				infoText = infoText_other;
  			} catch(e) { infoText = "";	}
  			
  			if(infoText == "") {
  				infoText="This is an encrypted, <font style='color:#ff0760;font-weight:bold;'>secure e-mail</font> for your privacy.<br/>To check your mail, please check and enter the information below.<br/><br/><div class='ly_body2'>Private customers : Resident on the 6-digit date of birth</div><br/><div class='ly_body2'> Corporate customers :10-digit Business Number</div><br/>";
  			}
  			
			var ly_body = document.getElementById("ly_body");
			ly_body.innerHTML=infoText;
			if( document.getElementById("confirm") )  
				document.getElementById("confirm").value="confirm";
			ly_body.style.letterSpacing="-0.1em";

			if(document.getElementById("ly_header"))
				document.getElementById("ly_header").innerHTML="Secure e-mail, password input";

			document.getElementById("password").placeholder="input password";

			vestmail_msg_download_link  = "Please click here to save.";
			vestmail_msg_wrong_password = "Enter password is invalid.";
			vestmail_msg_processing     = "Progress is being decoded.";
			vestmail_msg_not_supported_browser = "Unsupported Browser.";
			vestmail_msg_not_supported_attachfile = "Attached Files feature is not supported. Please check the details below.";
		}
			

		switch(theme) {
			case 1:
				document.getElementById("ly_header").style.background="url('data:image/png;base64,') no-repeat";
				document.getElementById("password").style.color="#ff0760";
				document.querySelector(".cryto_text").style.color="#ff0760";
			break;
			case 2:
				document.getElementById("ly_header").style.background="url('data:image/png;base64,') no-repeat";
				document.getElementById("password").style.color="#273441";
				document.querySelector(".cryto_text").style.color="#ff0760";
			break;
			case 3:
				document.getElementById("ly_header").style.background="url('data:image/png;base64,') no-repeat";
				document.getElementById("password").style.color="#ff0760";
				document.querySelector(".cryto_text").style.color="#ff0760";
			break;
			case 4:
				document.getElementById("ly_header").style.background="url('data:image/png;base64,') no-repeat";
				document.getElementById("password").style.color="#ff0760";
				document.querySelector(".cryto_text").style.color="#ff0760";
			break;
			case 5:
				document.getElementById("ly_header").style.background="url('data:image/png;base64,') no-repeat";
				document.getElementById("password").style.color="#0ead3b";
				document.querySelector(".cryto_text").style.color="#ff283d";
			break;
			case 6:
				document.getElementById("ly_header").style.background="url('data:image/png;base64,') no-repeat";
				document.getElementById("password").style.color="#ff283d";
				document.querySelector(".cryto_text").style.color="#ff283d";
			break;
			case 7:
				document.getElementById("ly_header").style.background="url('data:image/png;base64,') no-repeat";
				document.getElementById("password").style.color="#273441";
				document.querySelector(".cryto_text").style.color="#ff283d";
			break;
			default:
			break;
		}

		var elepwd = document.getElementById("password");

        /*
		if(window.vestmail_browser_info.mobile && navigator.userAgent.indexOf("Firefox") < 0) {
			elepwd.setAttribute("type", "number");
			elepwd.setAttribute("inputmode", "numeric");
			elepwd.setAttribute("pattern", "[0-9]*");
		}
        */
		if (elepwd) {
			elepwd.focus();
		}
	}
  
	function vestmail_onstart() {
		 var d = document.createElement('div');
		 d.id = "progressdlg";
		 d.style.position = "absolute";
		 d.style.top = "50%";
		 d.style.left = "50%";
		 d.style.margin = "-100px 0 0 -128px";
		 d.innerHTML = '<div style="width:256px;height:64px;background-repeat: no-repeat;background-position:center;background-image: url(data:image/gif;base64,);"></div><div align="center" style="width:256px; margin:10px 0px 0px 0px; font-weight:bold;color:#666666">loading...</div>';
		 document.body.appendChild(d);	
	}
	
	function vestmail_onend(isSuccess) {
		document.body.removeChild(document.getElementById('progressdlg'));
		if (isSuccess) {
			var aPrint = document.getElementById("print");
			if (aPrint) {
				aPrint.style.visibility = "visible";
			}
		}
	}

	function printIframe () {
		gVMObject.printIframe ();
	}
	
	function resizeFrame () {
		gVMObject.resizeFrame();
	}

    function isIE () {
          var agent = window.navigator.userAgent.toLowerCase();
          if ((navigator.appName == 'Netscape' && agent.indexOf('trident') != -1) || (agent.indexOf("msie") != -1))
              return true;
          else
              return false;
      }

    function setKeypad () {
      if ( typeof(vestmail_keypad) !== "undefined" && vestmail_keypad != '' && !isIE() && vestmail_keypad == 'true' ) {
          document.getElementById("password").style.width = "317px";
          document.getElementById("password").style.background = "url('data:image/png;base64,') no-repeat";

          document.getElementById("confirm").style.width = "84px";
          document.getElementById("confirm").style.background = "url('data:image/png;base64,') no-repeat";

          document.getElementById("keypad_img").style.display = "inline-block";
          document.getElementById("keypad_img").addEventListener("click", function() {
        	  var elepwd = document.getElementById("password");
              if (elepwd) {
                  if(gVMObject.keypadInit(elepwd) == true)
	                  if (!elepwd.classList.contains("keypad_ON"))
	                  	elepwd.className += " keypad_ON";  // 키패드 눌렀다는 플래그
                 // 키패드 닫으면 input 박스에 대한 이벤트 원복하는 API 추가 + "keypad_ON" 클래스 제거
              }
          });
      }
    }

      //]]>
    </script>
    <script type="text/javascript">
      //<![CDATA[
	var cpt_val = false;   
	var cpt_layer = null; 
	var esX, esY;
	// IE 구분
	var is_ie = (navigator.userAgent.indexOf("MSIE") != -1) ? true :false;

	function capture(obj_id, evt) {
		var evt = evt ? evt : event;

		cpt_layer = document.getElementById(obj_id);

		cpt_val = true;

		if(document.body && document.body.setCapture) {
			document.body.setCapture();
		}

		if(is_ie) {
			esX = evt.offsetX;
			esY = evt.offsetY;
		}
		else {
			esX = evt.clientX - (cpt_layer.offsetLeft ? cpt_layer.offsetLeft : 0);
			esY = evt.clientY - (cpt_layer.offsetTop  ? cpt_layer.offsetTop  : 0) ;
		}

		evt.cancelBubble = true;
		return false;
	}

	function drag_layer(evt) {
		cpt_layer = document.getElementById('pop_content');
		var evt = evt ? evt : event;
		if(cpt_val == true) {
			if(cpt_layer != null) {
				if(is_ie) {
					cpt_layer.style.left = evt.x + document.body.scrollLeft - esX + 'px';
					cpt_layer.style.top  = evt.y + document.body.scrollTop  - esY + 'px';
				}
				else {
					cpt_layer.style.left = evt.clientX - esX + 'px';
					cpt_layer.style.top  = evt.clientY - esY + 'px';
				}
				evt.cancelBubble = true;
				return false;
			}
		}
	}

	function release() {
		cpt_val = false;
		cpt_layer = null;
		if (document.body && document.body.releaseCapture) {
			document.body.releaseCapture();
		}
	}

	function close_layer(obj_id) {
		cpt_layer = document.getElementById(obj_id);
		cpt_layer.style.display = "none";
	}

	document.onmousemove = drag_layer;
	document.onmouseup   = release;
	//]]>
	</script>
	<!--  
		************************** 직접 수정 가능 영역	**************************
		
		1. banner : 고객사에서 사용할 배너이비지 URL 고객PC에서 접근이 가능하여야 한다
			- 서버 설정보다 우선적으로 적용됨
		
		2. 패스워드 안내 문구 ( 서버 설정보다 우선으로 적용됨 )
			2-1. textStr_ko : 패스워드 안내 메시지 ( 한글 브라우저 ) - html 코드 형태로 사용 가능
			2-2. textStr_en : 패스워드 안내 메시지 ( 영문 브라우저 ) - html 코드 형태로 사용 가능
			2-2. textStr_other : 패스워드 안내 메시지 ( 기타 브라우저 ) - html 코드 형태로 사용 가능 ( default 영문 )
			
		3. vmfile_url : 첨부파일 기능중 IE8 이하에서 flash 동작시 사용됨 ( default 사용 권장 )
		4. vestmail_msg_download_link : 첨부파일 이름이 없는 경우 보여중 링크 메시지
		5. theme : 패스워드창 타이틀 색
			0 : 검은색
			1 : 미드나이트블루
			2 : 틸
			3 : 스틸블루
			4 : 마젠타
			5 : 그린
			6 : 딥스카이블루
			7 : 오렌지
		*******************************************************************
	 -->    
    <script type="text/javascript">
      //<![CDATA[
		 	
	  var banner = "";
	  var textStr_ko = "";
	  var textStr_en = "";
	  var textStr_other = "";
	  	  
	  var vmfile_url = "http://download.yettiesoft.com/vestmail/vmfile.html";
	  var vestmail_msg_download_link='첨부파일';
	
	  var theme = 0;
	  //]]>
	  </script>
